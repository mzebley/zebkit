{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "sourceMap": true,
    "declaration": false,
    "noEmitOnError": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "src",
    "paths": {
      "@config": ["config/zebkit.ts"],
      "@definitions/*": ["definitions/*"],
      "@token-scripts/*": ["scripts/tokens/*"],
      "@component-scripts/*": ["scripts/components/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "scripts/*.ts",
    "build.ts",
    "src/**/*.test.ts"
  ]
}
