---
import type { TokenRow } from '../utils/token-docs';
import { getCssVarForReference } from '../utils/token-lookup';

interface Props {
  rows?: TokenRow[];
  showColorSwatches?: boolean;
  class?: string;
}

const {
  rows = [],
  showColorSwatches = true,
  class: className = '',
} = Astro.props as Props;

const tableClassName = ['token-table', className].filter(Boolean).join(' ');
---

<table class={tableClassName}>
  <thead>
    <tr>
      <th>Token</th>
      <th>Type</th>
      <th>Value</th>
      <th>Description</th>
    </tr>
  </thead>
  <tbody>
    {rows.map(({ token, type, value, description }) => {
      const cssVar =
        showColorSwatches && type === 'color'
          ? getCssVarForReference(value) ?? getCssVarForReference(token)
          : null;

      return (
        <tr>
          <td><code>{token}</code></td>
          <td>
            <code class="token-type">{type}</code>
          </td>
          <td>
            <span class:list={{ 'includes-swatch': cssVar }}>
              {cssVar && (
                <span
                  class="token-value-swatch"
                  aria-hidden="true"
                  title={`Preview of ${cssVar}`}
                  style={{ background: `var(${cssVar})` }}
                />
              )}
              <code>{String(value)}</code>
            </span>
          </td>
          <td>{description}</td>
        </tr>
      );
    })}
  </tbody>
</table>

<style>
  .token-type {
    display: inline-flex;
    min-width: max-content;
  }

  .includes-swatch {
    display: inline-flex;
    gap: 0.5rem;
    min-width: max-content;
    align-items: center;
  }

  .token-value-swatch {
    width: 1rem;
    height: 1rem;
    display: inline-block;
    border-radius: 999px;
    border: 1px solid var(--sl-color-gray-6);
  }
</style>
