{
  "name": "zebkit-docs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:generated": "node ./scripts/copy-tokens.js",
    "sync:tokens": "npm run build:tokens --prefix .. -- --config zebkit.docs.config.json && npm run build:hero-themes --prefix .. && npm run sync:generated",
    "refresh": "npm run build --prefix ..",
    "predev": "npm run refresh && svelte-kit sync",
    "dev": "vite dev",
    "prestart": "npm run refresh && svelte-kit sync",
    "start": "vite dev",
    "prebuild": "npm run refresh && svelte-kit sync",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.7.2",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "mdsvex": "^0.11.2",
    "rehype-slug": "^6.0.0",
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "remixicon": "^4.9.1"
  }
}
