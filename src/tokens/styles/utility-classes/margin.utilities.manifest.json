{
  "$schema": "../../../../schemas/utility-manifest.schema.json",
  "name": "Margin utilities",
  "key": "margin",
  "description": "Dictates spacing outside of the defined border of an element, separating it from neighboring elements.",
  "domain": "spacing",
  "layer": "utilities",
  "families": [
    {
      "name": "margin",
      "description": "Sets the empty space around an element.",
      "guidance": [
        "'block' margin values have no effect on elements with 'inline' display, they must be set to something like 'inline-block'",
        "Zebkit uses logical margin operators (inline/block) for improved international accessibility. 'block' is vertical, 'inline' is horizontal."
      ],
      "source": "src/tokens/styles/utility-classes/margin.scss",
      "properties": [
        "margin",
        "margin-block",
        "margin-block-start",
        "margin-block-end",
        "margin-inline",
        "margin-inline-start",
        "margin-inline-end"
      ],
      "tokens": {
        "group": "spacing",
        "varPrefix": "spacing",
        "types": [
          "dimension"
        ]
      },
      "pattern": {
        "base": "margin",
        "edges": [
          "block",
          "inline",
          "block-start",
          "block-end",
          "inline-start",
          "inline-end"
        ],
        "negativeValues": true,
        "literals": {
          "auto": "auto",
          "unset": "unset"

        },
        "exclude": [
