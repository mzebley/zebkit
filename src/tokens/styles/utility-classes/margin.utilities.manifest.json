            "margin-block"
          ],
          "inline": [
            "margin-inline"
          ],
          "inline-start": [
            "margin-inline-start"
          ],
          "inline-end": [
            "margin-inline-end"
          ],
          "block-start": [
            "margin-block-start"
          ],
          "block-end": [
            "margin-block-end"
          ]
        }
      },
      "modifiers": {
