      "description": "Paragraph styling and sibling spacing inside a .prose context.",
      "guidance": ["Prose paragraphs are max-width constrained (measure) for readability; wrap long-form copy in a .prose container rather than styling paragraphs ad hoc."],
      "source": "src/tokens/prose/styles.scss",
      "properties": ["font-family", "font-size", "font-weight", "line-height", "letter-spacing", "max-width", "color", "font-style", "text-transform", "margin-top"],
      "rules": [
        {
          "selector": ".prose > p, p.prose",
          "declarations": {
