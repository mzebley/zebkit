{
  "$schema": "../../../schemas/utility-manifest.schema.json",
  "name": "Prose utilities",
  "key": "prose",
  "description": "Opt-in long-form typographic context. Descendants of .prose (or elements that also carry .prose) get token-driven heading/paragraph styling and vertical rhythm. Element styles, emitted in @layer base so authored/component styles can still override.",
  "domain": "typography",
  "layer": "base",
  "families": [
    {
      "name": "prose-h1",
      "description": "Heading level 1 styling and sibling spacing inside a .prose context.",
      "source": "src/tokens/prose/styles.scss",
      "properties": ["font-family", "font-size", "font-weight", "line-height", "letter-spacing", "max-width", "color", "font-style", "text-transform", "margin-top"],
      "rules": [
        {
          "selector": ".prose > h1, h1.prose",
          "declarations": {
            "font-family": "var(--zbk-h1-font-family)",
            "font-size": "var(--zbk-h1-font-size)",
            "font-weight": "var(--zbk-h1-font-weight)",
            "line-height": "var(--zbk-h1-line-height)",
            "letter-spacing": "var(--zbk-h1-letter-spacing)",
            "max-width": "var(--zbk-h1-measure)",
            "color": "var(--zbk-h1-color)",
            "font-style": "var(--zbk-h1-font-style)",
            "text-transform": "var(--zbk-h1-text-transform)"
          }
        },
        { "selector": ".prose>*+h1", "declarations": { "margin-top": "var(--zbk-h1-spacing-before)" } },
        { "selector": ".prose>h1+*, h1.prose+*", "declarations": { "margin-top": "var(--zbk-h1-spacing-after)" } }
      ]
    },
    {
      "name": "prose-h2",
      "description": "Heading level 2 styling and sibling spacing inside a .prose context.",
      "source": "src/tokens/prose/styles.scss",
      "properties": ["font-family", "font-size", "font-weight", "line-height", "letter-spacing", "max-width", "color", "font-style", "text-transform", "margin-top"],
      "rules": [
        {
          "selector": ".prose > h2, h2.prose",
          "declarations": {
            "font-family": "var(--zbk-h2-font-family)",
            "font-size": "var(--zbk-h2-font-size)",
            "font-weight": "var(--zbk-h2-font-weight)",
            "line-height": "var(--zbk-h2-line-height)",
            "letter-spacing": "var(--zbk-h2-letter-spacing)",
            "max-width": "var(--zbk-h2-measure)",
            "color": "var(--zbk-h2-color)",
            "font-style": "var(--zbk-h2-font-style)",
            "text-transform": "var(--zbk-h2-text-transform)"
          }
        },
        { "selector": ".prose>*+h2", "declarations": { "margin-top": "var(--zbk-h2-spacing-before)" } },
        { "selector": ".prose>h2+*, h2.prose+*", "declarations": { "margin-top": "var(--zbk-h2-spacing-after)" } }
