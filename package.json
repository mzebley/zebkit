{
  "name": "zebkit",
  "version": "0.8.1",
  "workspaces": [
    "doc-site"
  ],
  "type": "module",
  "description": "A fully flexible, token-based web component library.",
  "bin": {
    "zebkit": "./dist/cli/zebkit.mjs"
  },
  "exports": {
    ".": "./dist/cli/zebkit.mjs",
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/cli/",
    "dist/components/",
    "dist/editor/",
    "custom-elements.json",
    "src/**/*.scss"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "jest",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "check:docs": "npm --prefix doc-site run build",
    "check:dtcg-baseline": "tsx -r tsconfig-paths/register scripts/check-dtcg-baseline.ts",
    "check:dtcg-validate": "tsx -r tsconfig-paths/register scripts/check-dtcg-validate.ts",
    "check": "npm run test:unit -- --runInBand && npm run test:integration && npm run type-check && npm run check:utilities && npm run check:palette && npm run lint && npm run check:cem && npm run check:context && npm run check:dtcg-baseline && npm run check:dtcg-validate && npm run check:docs",
    "lint": "npm run lint:components && npm run lint:utilities",
    "lint:utilities": "tsx -r tsconfig-paths/register src/scripts/utilities/lint.ts",
    "lint:components": "tsx -r tsconfig-paths/register src/scripts/components/lint.ts",
    "generate": "npm run generate:components && npm run generate:utilities && npm run generate:palette",
    "generate:components": "tsx -r tsconfig-paths/register src/scripts/components/generate.ts",
    "generate:utilities": "tsx -r tsconfig-paths/register src/scripts/utilities/generate.ts",
    "generate:palette": "tsx -r tsconfig-paths/register src/scripts/palette/generate.ts",
    "check:palette": "tsx -r tsconfig-paths/register src/scripts/palette/generate.ts --check",
    "check:utilities": "tsx -r tsconfig-paths/register src/scripts/utilities/generate.ts --check",
    "build": "npm run generate && npm run build:cem && npm run build:tokens -- --config theme/zebkit.docs.config.json && npm run build:hero-themes && npm run build:defaults && npm run build:components && npm --prefix doc-site run sync:generated && npm run build:context && npm run build:editor && npm run build:cli",
    "build:components": "tsx scripts/build-components.ts",
    "build-scripts": "tsc",
    "build:tokens": "tsx -r tsconfig-paths/register src/scripts/tokens/run.ts",
    "build:hero-themes": "tsx -r tsconfig-paths/register src/scripts/tokens/build-hero-themes.ts",
    "build:doc-token-data": "tsx -r tsconfig-paths/register scripts/build-doc-token-data.ts",
    "build:baseline-ref": "tsx -r tsconfig-paths/register src/scripts/tokens/build-baseline-reference.ts",
    "build:css": "npm run generate:utilities && npm run build:tokens",
    "build:defaults": "tsx -r tsconfig-paths/register scripts/build-defaults.ts",
    "build:editor": "tsx scripts/build-editor.ts",
    "build:cli": "tsx scripts/build-cli.ts",
    "prepare": "npm run build:defaults && npm run build:editor && npm run build:cli && npm run build:components",
    "prepublishOnly": "npm run check:utilities && npm run build:defaults && npm run build:context && npm run build:editor && npm run build:cli && npm run build:components",
    "docs:dev": "cd doc-site && npm run dev",
    "docs:build": "cd doc-site && npm run build",
    "build:cem": "custom-elements-manifest analyze",
    "check:cem": "custom-elements-manifest analyze && git diff --exit-code custom-elements.json",
    "build:context": "tsx scripts/build-agent-context.ts",
    "check:context": "npm --prefix doc-site run sync:tokens && npm run build:context && tsx scripts/assert-clean-paths.ts doc-site/static/zebkit doc-site/static/llms.txt doc-site/static/llms-full.txt doc-site/src/lib/data/generated"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mzebley/zebkit.git"
  },
  "keywords": [
    "a11y"
  ],
  "author": "Mark Zebley",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mzebley/zebkit/issues"
  },
  "homepage": "https://github.com/mzebley/zebkit#readme",
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "autoprefixer": "^10.4.20",
    "commander": "^12.0.0",
    "css-tree": "^3.2.1",
    "cssnano": "^7.0.5",
    "postcss": "^8.4.44",
    "postcss-preset-env": "^10.0.1",
    "postcss-selector-parser": "^6.1.2",
    "sass": "^1.78.0"
  },
  "peerDependencies": {
    "lit": ">=3.0.0"
  },
  "overrides": {
    "cookie": "^0.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-flow": "^7.24.7",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@types/css-tree": "^2.3.11",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.5.5",
    "ajv": "^8.20.0",
    "chalk": "^5.3.0",
    "core-js": "^3.38.1",
    "esbuild": "^0.25.12",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "inquirer": "^14.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lit": "^3.3.2",
    "ora": "^8.1.1",
    "regenerator-runtime": "^0.14.1",
    "rollup": "^4.21.2",
    "rollup-plugin-dts": "^6.1.1",
    "rollup-plugin-scss": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.7.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4",
    "zod": "^3.23.8"
  },
  "customElements": "custom-elements.json"
}
