# Penpot token sync — copy to .env and fill in your values

# Personal access token generated in Penpot → Settings → Access tokens
# Required for both penpot:push (optional upload) and penpot:pull (API mode)
PENPOT_ACCESS_TOKEN=

# UUID of the target Penpot file (visible in the file URL)
# Can also be set in zebkit.config.json as "penpot": { "fileId": "..." }
PENPOT_FILE_ID=

# Penpot instance URL — only needed for self-hosted installations
# Defaults to https://design.penpot.app when not set
# PENPOT_INSTANCE_URL=https://your-penpot-instance.example.com
