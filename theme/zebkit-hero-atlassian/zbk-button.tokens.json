{
  "ink": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Default button label color — white on the ADS primary button."
  },
  "ink-hover": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Label color when hovered."
  },
  "ink-active": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Label color when active or pressed."
  },
  "ink-disabled": {
    "$value": "{disabled.ink}",
    "$type": "color",
    "$description": "Label color for disabled buttons."
  },
  "canvas": {
    "$value": "{action.canvas}",
    "$type": "color",
    "$description": "Default button background — Atlassian blue (primary)."
  },
  "canvas-hover": {
    "$value": "{action.canvas-muted}",
    "$type": "color",
    "$description": "Background for hover state — ADS button-primary-hovered."
  },
  "canvas-active": {
    "$value": "{action.canvas-subtle}",
    "$type": "color",
    "$description": "Background for active/pressed state — ADS button-primary-pressed."
  },
  "canvas-disabled": {
    "$value": "{disabled.canvas}",
    "$type": "color",
    "$description": "Background for disabled buttons."
  },
  "border-color": {
    "$value": "{action.canvas}",
    "$type": "color",
    "$description": "Default button border color."
  },
  "border-color-hover": {
    "$value": "{action.canvas-muted}",
    "$type": "color",
    "$description": "Border color on hover."
  },
  "border-color-active": {
    "$value": "{action.canvas-subtle}",
    "$type": "color",
    "$description": "Border color when the button is selected/active."
  },
  "border-color-disabled": {
    "$value": "{disabled.border}",
    "$type": "color",
    "$description": "Border color for disabled buttons."
  },
  "border-width": {
    "$value": "0px",
    "$type": "dimension",
    "$description": "Base border width — ADS primary button is borderless."
  },
  "border-style": {
    "$value": "{border.style}",
    "$type": "borderStyle",
    "$description": "Border style for standard buttons."
  },
  "border-radius": {
    "$value": "{border.radius-md}",
    "$type": "dimension",
    "$description": "Corner radius — ADS button radius (4px)."
  },
  "font-family": {
    "$value": "{font-family.interface}",
    "$type": "fontFamily",
    "$description": "Font family for button labels."
  },
  "font-size": {
    "$value": "{font-size.sm}",
    "$type": "cssDimension",
    "$description": "Base font size for button labels — ADS button label (14px)."
  },
  "font-weight": {
    "$value": "{font-weight.medium}",
    "$type": "fontWeight",
    "$description": "Font weight for button labels — ADS Medium (500)."
  },
  "line-height": {
    "$value": "1.4285714286",
    "$type": "lineHeight",
    "$description": "Base line height for buttons — ADS (20/14)."
  },
  "letter-spacing": {
    "$value": "0",
    "$type": "cssDimension",
    "$description": "Letter spacing for button labels — ADS neutral tracking."
  },
  "text-transform": {
    "$value": "none",
    "$type": "textTransform",
    "$description": "Text transform for button labels."
  },
  "text-decoration": {
    "$value": "none",
    "$type": "textDecoration",
    "$description": "Text decoration for button labels."
  },
  "text-align": {
    "$value": "center",
    "$type": "textAlignment",
    "$description": "Text alignment for button content."
  },
  "padding-inline": {
    "$value": "{spacing.105}",
    "$type": "dimension",
    "$description": "Inline (horizontal) padding for standard buttons — ADS 12px gutter."
  },
  "padding-block": {
    "$value": "{spacing.025}",
    "$type": "dimension",
    "$description": "Block (vertical) padding (min-height drives the 32px ADS target)."
  },
  "gap": {
    "$value": "{spacing.025}",
    "$type": "dimension",
    "$description": "Gap between button icon and label — ADS 4px."
  },
  "group-gap": {
    "$value": "{spacing.025}",
    "$type": "dimension",
    "$description": "Gap between buttons when rendered in a group."
  },
  "justify-content": {
    "$value": "center",
    "$type": "flex",
    "$description": "Main axis alignment for button contents."
  },
  "min-height": {
    "$value": "32px",
    "$type": "dimension",
    "$description": "Minimum height — ADS default button is compact (32px)."
  },
  "min-width": {
    "$value": "44px",
    "$type": "dimension",
    "$description": "Minimum button width."
  },
  "icon-size": {
    "$value": "1rem",
    "$type": "cssDimension",
    "$description": "Default icon size within buttons — ADS 16px icon."
  },
  "focus-color": {
    "$value": "{focus.color}",
    "$type": "color",
    "$description": "Outline color for focus state."
  },
  "focus-width": {
    "$value": "{focus.width}",
    "$type": "dimension",
    "$description": "Outline width for focus state."
  },
  "focus-offset": {
    "$value": "{focus.offset}",
    "$type": "dimension",
    "$description": "Outline offset for focus state."
  },
  "box-shadow": {
    "$value": "none",
    "$type": "shadow",
    "$description": "Default box shadow — ADS buttons are flat."
  },
  "box-shadow-hover": {
    "$value": "none",
    "$type": "shadow",
    "$description": "Box shadow on hover."
  },
  "transition-duration": {
    "$value": "100ms",
    "$type": "duration",
    "$description": "Duration for hover/active transitions — ADS quick motion.",
    "$extensions": {
      "dev.zebkit": {
        "a11y": true
      }
    }
  },
  "transition-timing-function": {
    "$value": "ease-in-out",
    "$type": "transitionTimingFunction",
    "$description": "Timing function for button transitions."
  }
}
