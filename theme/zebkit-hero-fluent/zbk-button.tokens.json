{
  "ink": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Default button label color — Fluent colorNeutralForegroundOnBrand."
  },
  "ink-hover": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Label color when hovered."
  },
  "ink-active": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Label color when active or pressed."
  },
  "ink-disabled": {
    "$value": "{disabled.ink}",
    "$type": "color",
    "$description": "Label color for disabled buttons."
  },
  "canvas": {
    "$value": "{action.canvas}",
    "$type": "color",
    "$description": "Default button background — Fluent 2 primary (colorBrandBackground)."
  },
  "canvas-hover": {
    "$value": "{action.canvas-muted}",
    "$type": "color",
    "$description": "Background for hover state — Fluent colorBrandBackgroundHover."
  },
  "canvas-active": {
    "$value": "{action.canvas-subtle}",
    "$type": "color",
    "$description": "Background for active/pressed state — Fluent colorBrandBackgroundPressed."
  },
  "canvas-disabled": {
    "$value": "{disabled.canvas}",
    "$type": "color",
    "$description": "Background for disabled buttons."
  },
  "border-color": {
    "$value": "{action.canvas}",
    "$type": "color",
    "$description": "Default button border color."
  },
  "border-color-hover": {
    "$value": "{action.canvas-muted}",
    "$type": "color",
    "$description": "Border color on hover."
  },
  "border-color-active": {
    "$value": "{action.canvas-subtle}",
    "$type": "color",
    "$description": "Border color when the button is selected/active."
  },
  "border-color-disabled": {
    "$value": "{disabled.border}",
    "$type": "color",
    "$description": "Border color for disabled buttons."
  },
  "border-width": {
    "$value": "0px",
    "$type": "borderWidth",
    "$description": "Base border width — Fluent 2 primary button is borderless."
  },
  "border-style": {
    "$value": "{border.style}",
    "$type": "borderStyle",
    "$description": "Border style for standard buttons."
  },
  "border-radius": {
    "$value": "{border.radius-sm}",
    "$type": "borderRadius",
    "$description": "Corner radius — Fluent borderRadiusMedium (4px)."
  },
  "font-family": {
    "$value": "{font-family.interface}",
    "$type": "fontFamily",
    "$description": "Font family for button labels."
  },
  "font-size": {
    "$value": "{font-size.sm}",
    "$type": "fontSize",
    "$description": "Base font size for button labels — Fluent 2 button (14px)."
  },
  "font-weight": {
    "$value": "{font-weight.semibold}",
    "$type": "fontWeight",
    "$description": "Font weight for button labels — Fluent 2 buttons use Semibold."
  },
  "line-height": {
    "$value": "1.4285714286",
    "$type": "lineHeight",
    "$description": "Base line height for buttons — Fluent 2 (20/14)."
  },
  "letter-spacing": {
    "$value": "0",
    "$type": "letterSpacing",
    "$description": "Letter spacing for button labels — Fluent neutral tracking."
  },
  "text-transform": {
    "$value": "none",
    "$type": "textTransform",
    "$description": "Text transform for button labels."
  },
  "text-decoration": {
    "$value": "none",
    "$type": "textDecoration",
    "$description": "Text decoration for button labels."
  },
  "text-align": {
    "$value": "center",
    "$type": "textAlignment",
    "$description": "Text alignment for button content."
  },
  "padding-inline": {
    "$value": "0.75rem",
    "$type": "spacing",
    "$description": "Inline (horizontal) padding for standard buttons — Fluent 2 12px gutter."
  },
  "padding-block": {
    "$value": "{spacing.025}",
    "$type": "spacing",
    "$description": "Block (vertical) padding (min-height drives the 32px Fluent target)."
  },
  "gap": {
    "$value": "{spacing.025}",
    "$type": "spacing",
    "$description": "Gap between button icon and label — Fluent 2 spacingHorizontalSNudge."
  },
  "group-gap": {
    "$value": "{spacing.025}",
    "$type": "spacing",
    "$description": "Gap between buttons when rendered in a group."
  },
  "justify-content": {
    "$value": "center",
    "$type": "flex",
    "$description": "Main axis alignment for button contents."
  },
  "min-height": {
    "$value": "32px",
    "$type": "sizing",
    "$description": "Minimum height — Fluent 2 medium button (32px)."
  },
  "min-width": {
    "$value": "44px",
    "$type": "sizing",
    "$description": "Minimum button width."
  },
  "icon-size": {
    "$value": "1.25rem",
    "$type": "sizing",
    "$description": "Default icon size within buttons — Fluent 2 20px icon."
  },
  "focus-color": {
    "$value": "{focus.color}",
    "$type": "color",
    "$description": "Outline color for focus state."
  },
  "focus-width": {
    "$value": "{focus.width}",
    "$type": "borderWidth",
    "$description": "Outline width for focus state."
  },
  "focus-offset": {
    "$value": "{focus.offset}",
    "$type": "spacing",
    "$description": "Outline offset for focus state."
  },
  "box-shadow": {
    "$value": "none",
    "$type": "boxShadow",
    "$description": "Default box shadow — Fluent 2 buttons are flat."
  },
  "box-shadow-hover": {
    "$value": "none",
    "$type": "boxShadow",
    "$description": "Box shadow on hover."
  },
  "transition-duration": {
    "$value": "100ms",
    "$type": "transition",
    "$description": "Duration for hover/active transitions — Fluent 2 durationFaster.",
    "$extensions": {
      "dev.zebkit": {
        "a11y": true
      }
    }
  },
  "transition-timing-function": {
    "$value": "cubic-bezier(0.33, 0, 0.67, 1)",
    "$type": "transition",
    "$description": "Timing function — Fluent 2 curveEasyEase."
  }
}
