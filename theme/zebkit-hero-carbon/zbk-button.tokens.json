{
  "ink": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Default button label color."
  },
  "ink-hover": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Label color when hovered."
  },
  "ink-active": {
    "$value": "{color.global-white}",
    "$type": "color",
    "$description": "Label color when active or pressed."
  },
  "ink-disabled": {
    "$value": "{disabled.ink}",
    "$type": "color",
    "$description": "Label color for disabled buttons."
  },
  "canvas": {
    "$value": "{action.canvas}",
    "$type": "color",
    "$description": "Default button background — Carbon interactive blue."
  },
  "canvas-hover": {
    "$value": "{action.canvas-muted}",
    "$type": "color",
    "$description": "Background for hover state — Carbon $button-primary-hover."
  },
  "canvas-active": {
    "$value": "{action.canvas-subtle}",
    "$type": "color",
    "$description": "Background for active/pressed state — Carbon $button-primary-active."
  },
  "canvas-disabled": {
    "$value": "{disabled.canvas}",
    "$type": "color",
    "$description": "Background for disabled buttons."
  },
  "border-color": {
    "$value": "{action.canvas}",
    "$type": "color",
    "$description": "Default button border color."
  },
  "border-color-hover": {
    "$value": "{action.canvas-muted}",
    "$type": "color",
    "$description": "Border color on hover."
  },
  "border-color-active": {
    "$value": "{action.canvas-subtle}",
    "$type": "color",
    "$description": "Border color when the button is selected/active."
  },
  "border-color-disabled": {
    "$value": "{disabled.border}",
    "$type": "color",
    "$description": "Border color for disabled buttons."
  },
  "border-width": {
    "$value": "0px",
    "$type": "dimension",
    "$description": "Base border width — Carbon primary button is borderless."
  },
  "border-style": {
    "$value": "{border.style}",
    "$type": "borderStyle",
    "$description": "Border style for standard buttons."
  },
  "border-radius": {
    "$value": "{border.radius-md}",
    "$type": "dimension",
    "$description": "Corner radius — Carbon buttons are square-cornered (0)."
  },
  "font-family": {
    "$value": "{font-family.interface}",
    "$type": "fontFamily",
    "$description": "Font family for button labels."
  },
  "font-size": {
    "$value": "{font-size.xs}",
    "$type": "cssDimension",
    "$description": "Base font size for button labels — Carbon body-compact (14px)."
  },
  "font-weight": {
    "$value": "{font-weight.normal}",
    "$type": "fontWeight",
    "$description": "Font weight for button labels — Carbon Regular."
  },
  "line-height": {
    "$value": "1.2857142857",
    "$type": "lineHeight",
    "$description": "Base line height for buttons — Carbon body-compact-01 (18/14)."
  },
  "letter-spacing": {
    "$value": "0.16px",
    "$type": "cssDimension",
    "$description": "Letter spacing for button labels — Carbon body-compact tracking."
  },
  "text-transform": {
    "$value": "none",
    "$type": "textTransform",
    "$description": "Text transform for button labels."
  },
  "text-decoration": {
    "$value": "none",
    "$type": "textDecoration",
    "$description": "Text decoration for button labels."
  },
  "text-align": {
    "$value": "left",
    "$type": "textAlignment",
    "$description": "Text alignment for button content — Carbon left-aligns button labels."
  },
  "padding-inline": {
    "$value": "{spacing.1}",
    "$type": "dimension",
    "$description": "Inline (horizontal) padding for standard buttons — Carbon 16px gutter."
  },
  "padding-block": {
    "$value": "{spacing.05}",
    "$type": "dimension",
    "$description": "Block (vertical) padding for standard buttons (min-height drives the 48px Carbon target)."
  },
  "gap": {
    "$value": "{spacing.05}",
    "$type": "dimension",
    "$description": "Gap between button icon and label."
  },
  "group-gap": {
    "$value": "{spacing.1px}",
    "$type": "dimension",
    "$description": "Gap between buttons in a group — Carbon hairline rule between actions."
  },
  "justify-content": {
    "$value": "flex-start",
    "$type": "flex",
    "$description": "Main axis alignment — Carbon pushes the label to the start."
  },
  "min-height": {
    "$value": "48px",
    "$type": "dimension",
    "$description": "Minimum height — Carbon productive button (48px)."
  },
  "min-width": {
    "$value": "44px",
    "$type": "dimension",
    "$description": "Minimum button width."
  },
  "icon-size": {
    "$value": "1rem",
    "$type": "cssDimension",
    "$description": "Default icon size within buttons — Carbon 16px icon."
  },
  "focus-color": {
    "$value": "{focus.color}",
    "$type": "color",
    "$description": "Outline color for focus state."
  },
  "focus-width": {
    "$value": "{focus.width}",
    "$type": "dimension",
    "$description": "Outline width for focus state."
  },
  "focus-offset": {
    "$value": "{focus.offset}",
    "$type": "dimension",
    "$description": "Outline offset for focus state."
  },
  "box-shadow": {
    "$value": "none",
    "$type": "shadow",
    "$description": "Default box shadow for buttons — Carbon is flat."
  },
  "box-shadow-hover": {
    "$value": "none",
    "$type": "shadow",
    "$description": "Box shadow on hover."
  },
  "transition-duration": {
    "$value": "70ms",
    "$type": "duration",
    "$description": "Duration for hover/active transitions — Carbon fast-01 motion.",
    "$extensions": {
      "dev.zebkit": {
        "a11y": true
      }
    }
  },
  "transition-timing-function": {
    "$value": "cubic-bezier(0, 0, 0.38, 0.9)",
    "$type": "transitionTimingFunction",
    "$description": "Timing function — Carbon productive standard easing."
  }
}
