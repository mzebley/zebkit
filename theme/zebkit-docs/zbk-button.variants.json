{
  "button": {
    "ghost": {
      "axis": "style",
      "description": "Transparent canvas and border; ink takes the action role with a subtle hover wash.",
      "overrides": {
        "canvas": "transparent",
        "canvas-hover": "transparent",
        "canvas-active": "transparent",
        "ink": "{action.ink}",
        "ink-hover": "{action.ink-emphasis}",
        "ink-active": "{action.ink}",
        "border-color": "transparent",
        "border-color-hover": "transparent",
        "border-color-active": "transparent",
        "border-color-disabled": "transparent",
        "box-shadow-hover": "none",
        "transform-hover": "translateY(0)"
      }
    },
    "lg": {
      "axis": "size",
      "description": "Larger type and padding.",
      "overrides": {
        "border-radius": "{border.radius-md}",
        "font-size": "{font-size.md}",
        "padding-inline": "{spacing.lg}",
        "padding-block": "{spacing.sm}",
        "line-height": "{line-height.5}"
      }
    },
    "outline": {
      "axis": "style",
      "overrides": {
        "canvas": "transparent",
        "canvas-hover": "{button.canvas}",
        "canvas-active": "{action.ink-inverse-emphasis}",
        "canvas-disabled": "transparent",
        "ink": "{action.ink}",
        "ink-hover": "{action.ink-emphasis}",
        "ink-active": "{action.ink-emphasis}",
        "ink-disabled": "{disabled.ink-inverse-muted}",
        "border-color": "{button.ink}",
        "border-width": "{border.width-sm}",
        "border-radius": "{border.radius-md}",
        "border-color-hover": "{button.ink-hover}",
        "border-color-active": "{button.ink-active}",
        "border-color-disabled": "{button.ink-disabled}",
        "box-shadow-hover": "none",
        "transform": "scale(1)",
        "transform-hover": "translateY(0) scale(1)",
        "transform-active": "scale(.9725)"
      }
    },
    "sm": {
      "axis": "size",
      "overrides": {
        "font-size": "{font-size.xs}",
        "padding-inline": "{spacing.sm}",
        "padding-block": "{spacing.xs}"
      }
    },
    "subtle": {
      "axis": "style",
      "description": "Low-emphasis fill on the subtle action canvas; no border.",
      "overrides": {
        "canvas": "{app.canvas-muted}",
        "canvas-hover": "{app.canvas-muted}",
        "canvas-active": "{app.canvas-muted}",
        "ink": "{action.ink}",
        "ink-hover": "{action.ink-emphasis}",
        "ink-active": "{action.ink-emphasis}",
        "border-color": "transparent",
        "border-color-hover": "transparent",
        "border-color-active": "transparent",
        "border-radius": "{border.radius-md}"
      }
    }
  }
}