    "shadowToken": {
      "type": "object",
      "description": "No shadow.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/shadowValue"
        },
        "$type": {
          "const": "shadow"
        },
        "$description": {
          "type": "string"
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      }
    },
    "deprecated": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ]
    },
    "groupType": {
      "type": "string",
      "enum": [
        "color",
        "dimension",
        "duration",
        "fontFamily",
        "fontWeight",
        "cubicBezier",
        "number",
        "strokeStyle",
        "shadow",
        "display",
        "cursor",
        "textTransform",
        "textDecoration",
        "textAlignment",
        "fontStyle",
        "transform",
        "transitionProperty",
        "transitionTimingFunction",
        "content",
        "flex",
        "utility",
        "asset",
        "boolean",
        "cssDimension"
      ]
    },
    "groupExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": false,
              "properties": {
                "min-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        }
      },
      "patternProperties": {
        "^(?!dev\\.zebkit$).+": {}
      }
    },
    "group:inner": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "$type": {
          "$ref": "#/definitions/groupType"
        },
        "$description": {
          "type": "string"
        },
        "$deprecated": {
