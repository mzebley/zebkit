                        "type": "object",
                        "required": [
                          "value",
                          "unit"
                        ],
                        "additionalProperties": false,
                        "properties": {
                          "value": {
                            "type": "number"
                          },
                          "unit": {
                            "type": "string",
                            "enum": [
                              "px",
                              "rem"
                            ]
                          }
                        }
                      },
                      {
                        "type": "string",
                        "pattern": "^\\{[^{}]+\\}$"
                      }
                    ]
                  },
                  "inset": {
                    "type": "boolean"
                  }
                }
              },
              {
                "type": "string",
                "pattern": "^\\{[^{}]+\\}$"
              }
            ]
          }
        }
      ],
      "examples": [
        "{elevation.none}",
        "{elevation.xs}",
        "{elevation.sm}",
        "{elevation.md}",
        "{elevation.lg}",
        "{elevation.xl}",
        "{elevation.2xl}",
        "{elevation.inner}",
        "{elevation.inner-sm}",
        "{elevation.inner-lg}",
        "{button.box-shadow}",
        "{button.box-shadow-hover}",
        "{button.box-shadow-active}",
        "{button.box-shadow-focus}",
        "{checkbox.box-shadow}",
        "{checkbox.box-shadow-hover}",
        "{checkbox.box-shadow-active}",
        "{checkbox.box-shadow-checked}",
        "{checkbox.box-shadow-focus}",
        "{input.box-shadow}",
        "{input.box-shadow-hover}",
        "{input.box-shadow-focus}",
        "{input.box-shadow-active}",
        "{input.box-shadow-invalid}",
        "{radio.box-shadow}",
        "{radio.box-shadow-hover}",
        "{radio.box-shadow-active}",
        "{radio.box-shadow-checked}",
        "{radio.box-shadow-focus}",
        "{select.box-shadow}",
        "{select.box-shadow-hover}",
        "{select.box-shadow-focus}",
        "{select.box-shadow-active}",
        "{select.box-shadow-invalid}",
        "{textarea.box-shadow}",
        "{textarea.box-shadow-hover}",
        "{textarea.box-shadow-focus}",
        "{textarea.box-shadow-active}",
        "{textarea.box-shadow-invalid}",
        "{toggle.box-shadow}",
        "{toggle.box-shadow-hover}",
        "{toggle.box-shadow-active}",
        "{toggle.box-shadow-checked}",
        "{toggle.box-shadow-focus}",
        "{toggle.thumb-shadow}",
        "{toggle.thumb-shadow-hover}",
        "{toggle.thumb-shadow-active}",
        "{toggle.thumb-shadow-checked}",
