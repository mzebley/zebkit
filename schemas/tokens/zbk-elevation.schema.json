                    "colorSpace",
                    "components"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "colorSpace": {
                      "type": "string",
                      "enum": [
                        "srgb",
                        "srgb-linear",
                        "hsl",
                        "hwb",
                        "lab",
                        "lch",
                        "oklab",
                        "oklch",
                        "display-p3",
                        "a98-rgb",
                        "prophoto-rgb",
                        "rec2020",
                        "xyz-d65",
                        "xyz-d50"
                      ]
                    },
                    "components": {
                      "type": "array",
                      "minItems": 3,
                      "maxItems": 3,
                      "items": {
                        "oneOf": [
                          {
                            "type": "number"
                          },
                          {
                            "const": "none"
                          }
                        ]
                      }
                    },
                    "alpha": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "hex": {
                      "type": "string",
                      "pattern": "^#[0-9a-fA-F]{6}$"
                    }
                  }
                },
                {
                  "type": "string",
                  "pattern": "^\\{[^{}]+\\}$"
                }
              ]
            },
            "offsetX": {
              "oneOf": [
                {
                  "type": "object",
                  "required": [
                    "value",
                    "unit"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "value": {
                      "type": "number"
                    },
                    "unit": {
                      "type": "string",
                      "enum": [
                        "px",
                        "rem"
                      ]
                    }
                  }
                },
                {
                  "type": "string",
                  "pattern": "^\\{[^{}]+\\}$"
                }
              ]
            },
            "offsetY": {
              "oneOf": [
                {
                  "type": "object",
                  "required": [
                    "value",
                    "unit"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "value": {
                      "type": "number"
                    },
                    "unit": {
                      "type": "string",
                      "enum": [
                        "px",
                        "rem"
                      ]
                    }
                  }
                },
                {
                  "type": "string",
                  "pattern": "^\\{[^{}]+\\}$"
                }
              ]
            },
            "blur": {
              "oneOf": [
                {
                  "type": "object",
                  "required": [
                    "value",
                    "unit"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "value": {
                      "type": "number"
                    },
                    "unit": {
                      "type": "string",
                      "enum": [
                        "px",
                        "rem"
                      ]
                    }
                  }
                },
                {
                  "type": "string",
                  "pattern": "^\\{[^{}]+\\}$"
                }
              ]
            },
            "spread": {
              "oneOf": [
                {
                  "type": "object",
                  "required": [
                    "value",
                    "unit"
                  ],
                  "additionalProperties": false,
                  "properties": {
                    "value": {
                      "type": "number"
                    },
                    "unit": {
                      "type": "string",
                      "enum": [
                        "px",
                        "rem"
                      ]
                    }
                  }
                },
                {
                  "type": "string",
                  "pattern": "^\\{[^{}]+\\}$"
                }
              ]
            },
            "inset": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "object",
                "required": [
                  "color",
                  "offsetX",
                  "offsetY",
                  "blur",
                  "spread"
                ],
                "additionalProperties": false,
                "properties": {
                  "color": {
                    "oneOf": [
