        },
        "$extensions": {
          "$ref": "#/definitions/groupExtensions"
        },
        "sm": {
          "description": "Small inner shadow.",
          "allOf": [
            {
              "$ref": "#/definitions/shadowToken"
            }
          ]
        },
        "lg": {
          "description": "Large inner shadow.",
          "allOf": [
