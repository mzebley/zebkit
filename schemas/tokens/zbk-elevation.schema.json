                                  "type": "number"
                                },
                                {
                                  "const": "none"
                                }
                              ]
                            }
                          },
                          "alpha": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "hex": {
                            "type": "string",
                            "pattern": "^#[0-9a-fA-F]{6}$"
                          }
                        }
                      },
                      {
                        "type": "string",
                        "pattern": "^\\{[^{}]+\\}$"
                      }
                    ]
                  },
                  "offsetX": {
                    "oneOf": [
                      {
                        "type": "object",
                        "required": [
                          "value",
                          "unit"
                        ],
                        "additionalProperties": false,
                        "properties": {
                          "value": {
                            "type": "number"
                          },
                          "unit": {
                            "type": "string",
                            "enum": [
                              "px",
                              "rem"
                            ]
                          }
                        }
                      },
                      {
                        "type": "string",
                        "pattern": "^\\{[^{}]+\\}$"
                      }
                    ]
                  },
                  "offsetY": {
                    "oneOf": [
                      {
                        "type": "object",
                        "required": [
                          "value",
                          "unit"
                        ],
                        "additionalProperties": false,
                        "properties": {
                          "value": {
                            "type": "number"
                          },
                          "unit": {
                            "type": "string",
                            "enum": [
                              "px",
                              "rem"
                            ]
                          }
                        }
                      },
                      {
                        "type": "string",
                        "pattern": "^\\{[^{}]+\\}$"
                      }
                    ]
                  },
                  "blur": {
                    "oneOf": [
                      {
                        "type": "object",
                        "required": [
                          "value",
                          "unit"
                        ],
                        "additionalProperties": false,
                        "properties": {
                          "value": {
                            "type": "number"
                          },
                          "unit": {
                            "type": "string",
                            "enum": [
                              "px",
                              "rem"
                            ]
                          }
                        }
                      },
                      {
                        "type": "string",
                        "pattern": "^\\{[^{}]+\\}$"
                      }
                    ]
