        "{textarea.box-shadow-active}",
        "{textarea.box-shadow-invalid}",
        "{toggle.box-shadow}",
        "{toggle.box-shadow-hover}",
        "{toggle.box-shadow-active}",
        "{toggle.box-shadow-checked}",
        "{toggle.box-shadow-focus}",
        "{toggle.thumb-shadow}",
        "{toggle.thumb-shadow-hover}",
        "{toggle.thumb-shadow-active}",
        "{toggle.thumb-shadow-checked}",
        "{tooltip.box-shadow}"
      ]
    }
  },
  "properties": {
    "$extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": {
                "oneOf": [
                  {
                    "type": [
                      "string",
                      "number"
                    ]
                  },
                  {
                    "type": "object",
                    "required": [
                      "value",
                      "unit"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "value": {
                        "type": "number"
                      },
                      "unit": {
                        "type": "string",
                        "enum": [
                          "px",
                          "rem"
                        ]
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    "none": {
      "type": "object",
      "description": "No shadow.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
