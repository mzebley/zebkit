    "dimensionToken": {
      "type": "object",
      "description": "Zero spacing.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "anyOf": [
            {
              "$ref": "#/definitions/dimensionValue"
            },
            {
              "$ref": "#/definitions/cssDimensionValue"
            }
          ]
        },
        "$type": {
          "type": "string",
          "enum": [
            "dimension",
            "cssDimension"
          ]
        },
        "$description": {
          "type": "string",
          "minLength": 1
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "$type"
            ],
            "properties": {
              "$type": {
                "const": "dimension"
              }
            }
          },
          "then": {
            "properties": {
              "$value": {
                "$ref": "#/definitions/dimensionValue"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "$type"
            ],
            "properties": {
              "$type": {
                "const": "cssDimension"
              }
            }
          },
          "then": {
            "properties": {
              "$value": {
                "$ref": "#/definitions/cssDimensionValue"
              }
            }
          }
        }
      ]
    },
    "deprecated": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ]
    },
    "groupExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": false,
              "properties": {
                "min-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
