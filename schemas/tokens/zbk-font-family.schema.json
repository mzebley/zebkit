{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-font-family Token Overrides",
  "description": "Authorable overrides for the zbk-font-family token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "fontFamilyValue": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "examples": [
            "{font-family.system-sans}",
            "{font-family.system-serif}",
            "{font-family.system-mono}"
          ]
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ],
      "examples": [
        "{h1.font-family}",
        "{h2.font-family}",
        "{h3.font-family}",
        "{h4.font-family}",
        "{h5.font-family}",
        "{h6.font-family}",
        "{lede.font-family}",
        "{list.font-family}",
        "{p.font-family}",
        "{font-family.primary}",
        "{font-family.alt}",
        "{font-family.monospace}",
        "{font-family.interface}",
        "{font-family.heading}",
        "{font-family.body}",
        "{font-family.code}",
        "{button.font-family}",
        "{checkbox.font-family}",
        "{input.font-family}",
        "{pagination.font-family}",
        "{radio.font-family}",
        "{select.font-family}",
        "{textarea.font-family}",
        "{toggle.font-family}",
        "{tooltip.font-family}"
      ]
    },
    "cssFontFamilyValue": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "{font-family.system-sans}",
        "{font-family.system-serif}",
        "{font-family.system-mono}"
      ]
    },
    "fontFamilyToken": {
      "type": "object",
      "description": "Primary font family for use in the system. Usually used for body content and interface items.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "anyOf": [
            {
              "$ref": "#/definitions/fontFamilyValue"
            },
            {
              "$ref": "#/definitions/cssFontFamilyValue"
            }
          ]
        },
        "$type": {
          "type": "string",
          "enum": [
            "fontFamily",
            "cssFontFamily"
          ]
        },
        "$description": {
          "type": "string",
          "minLength": 1
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                },
                "font": {
                  "type": "object",
                  "description": "Font-loading metadata for this family.",
                  "additionalProperties": false,
                  "properties": {
                    "source": {
                      "type": "string",
                      "enum": [
                        "system",
                        "google",
                        "local"
                      ],
                      "description": "Where this font family is loaded from."
                    },
                    "fallback": {
                      "type": "string",
                      "enum": [
                        "sans",
                        "serif",
                        "mono"
                      ],
                      "description": "Fallback stack category appended to the authored family."
                    },
                    "weights": {
                      "description": "Static font weights or a variable-font range such as 200..800.",
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "array",
                          "items": {
                            "type": [
                              "string",
                              "number"
                            ]
                          },
                          "uniqueItems": true
                        }
                      ]
                    },
                    "styles": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": [
                          "normal",
                          "italic"
                        ]
                      },
                      "uniqueItems": true
                    },
                    "faces": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "src"
                        ],
                        "additionalProperties": false,
                        "properties": {
                          "src": {
                            "type": "string"
                          },
                          "weight": {
                            "type": [
                              "string",
                              "number"
                            ]
                          },
                          "style": {
                            "type": "string",
                            "enum": [
                              "normal",
                              "italic",
                              "oblique"
                            ]
                          },
                          "display": {
                            "type": "string",
                            "enum": [
                              "auto",
                              "block",
                              "swap",
                              "fallback",
                              "optional"
                            ]
                          },
                          "format": {
                            "type": "string"
                          },
                          "unicodeRange": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "display": {
                      "type": "string",
                      "enum": [
                        "auto",
                        "block",
                        "swap",
                        "fallback",
                        "optional"
                      ]
                    }
                  }
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "$type"
            ],
            "properties": {
              "$type": {
                "const": "fontFamily"
              }
            }
          },
          "then": {
            "properties": {
              "$value": {
                "$ref": "#/definitions/fontFamilyValue"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "$type"
            ],
            "properties": {
              "$type": {
                "const": "cssFontFamily"
              }
            }
          },
          "then": {
            "properties": {
              "$value": {
                "$ref": "#/definitions/cssFontFamilyValue"
              }
            }
          }
        }
      ]
    },
    "cssFontFamilyToken": {
      "type": "object",
      "description": "System sans-serif stack. Zero network cost; uses the platform UI font.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/cssFontFamilyValue"
        },
        "$type": {
          "const": "cssFontFamily"
        },
        "$description": {
          "type": "string",
          "minLength": 1
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                },
                "font": {
                  "type": "object",
                  "description": "Font-loading metadata for this family.",
                  "additionalProperties": false,
                  "properties": {
                    "source": {
                      "type": "string",
                      "enum": [
                        "system",
                        "google",
                        "local"
                      ],
                      "description": "Where this font family is loaded from."
                    },
                    "fallback": {
                      "type": "string",
                      "enum": [
                        "sans",
                        "serif",
                        "mono"
                      ],
                      "description": "Fallback stack category appended to the authored family."
                    },
                    "weights": {
                      "description": "Static font weights or a variable-font range such as 200..800.",
                      "oneOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "array",
                          "items": {
                            "type": [
                              "string",
                              "number"
                            ]
                          },
                          "uniqueItems": true
                        }
                      ]
                    },
                    "styles": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "enum": [
                          "normal",
                          "italic"
                        ]
                      },
                      "uniqueItems": true
                    },
                    "faces": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "src"
                        ],
                        "additionalProperties": false,
                        "properties": {
                          "src": {
                            "type": "string"
                          },
                          "weight": {
                            "type": [
                              "string",
                              "number"
                            ]
                          },
                          "style": {
                            "type": "string",
                            "enum": [
                              "normal",
                              "italic",
                              "oblique"
                            ]
                          },
                          "display": {
                            "type": "string",
                            "enum": [
                              "auto",
                              "block",
                              "swap",
                              "fallback",
                              "optional"
                            ]
                          },
                          "format": {
                            "type": "string"
                          },
                          "unicodeRange": {
                            "type": "string"
                          }
                        }
                      }
                    },
                    "display": {
                      "type": "string",
                      "enum": [
                        "auto",
                        "block",
                        "swap",
                        "fallback",
                        "optional"
                      ]
                    }
                  }
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      }
    },
    "deprecated": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ]
    },
    "groupExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": false,
              "properties": {
                "min-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        }
      },
      "patternProperties": {
        "^(?!dev\\.zebkit$).+": {}
      }
    },
    "group:system": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "$type": {
          "type": "string",
          "enum": [
            "fontFamily",
            "cssFontFamily"
          ]
        },
        "$description": {
          "type": "string",
          "minLength": 1
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "$ref": "#/definitions/groupExtensions"
        },
        "sans": {
          "description": "System sans-serif stack. Zero network cost; uses the platform UI font.",
          "allOf": [
            {
              "$ref": "#/definitions/cssFontFamilyToken"
            }
          ]
        },
        "serif": {
          "description": "System serif stack. Zero network cost.",
          "allOf": [
            {
              "$ref": "#/definitions/cssFontFamilyToken"
            }
          ]
        },
        "mono": {
          "description": "System monospace stack. Zero network cost.",
          "allOf": [
            {
              "$ref": "#/definitions/cssFontFamilyToken"
            }
          ]
        }
      }
    }
  },
  "properties": {
    "$type": {
      "type": "string",
      "enum": [
        "fontFamily",
        "cssFontFamily"
      ]
    },
    "$description": {
      "type": "string",
      "minLength": 1
    },
    "$deprecated": {
      "$ref": "#/definitions/deprecated"
    },
    "$extensions": {
      "$ref": "#/definitions/groupExtensions"
    },
    "primary": {
      "description": "Primary font family for use in the system. Usually used for body content and interface items.",
      "allOf": [
        {
          "$ref": "#/definitions/fontFamilyToken"
        }
      ]
    },
    "alt": {
      "description": "Alternate font family for use in the system. Primarily used for headings.",
      "allOf": [
        {
          "$ref": "#/definitions/fontFamilyToken"
        }
      ]
    },
    "monospace": {
      "description": "Monospaced font family for use in the system. Primarily used for displaying code or for accessibility.",
      "allOf": [
        {
          "$ref": "#/definitions/fontFamilyToken"
        }
      ]
    },
    "system": {
      "$ref": "#/definitions/group:system"
    },
    "system-sans": {
      "description": "System sans-serif stack. Zero network cost; uses the platform UI font.",
      "allOf": [
        {
          "$ref": "#/definitions/cssFontFamilyToken"
        }
      ]
    },
    "system-serif": {
      "description": "System serif stack. Zero network cost.",
      "allOf": [
        {
          "$ref": "#/definitions/cssFontFamilyToken"
        }
      ]
    },
    "system-mono": {
      "description": "System monospace stack. Zero network cost.",
      "allOf": [
        {
          "$ref": "#/definitions/cssFontFamilyToken"
        }
      ]
    },
    "interface": {
      "description": "Font family used for things like buttons or input fields.",
      "allOf": [
        {
          "$ref": "#/definitions/fontFamilyToken"
        }
      ]
    },
    "heading": {
      "description": "Font family used for heading elements.",
      "allOf": [
        {
          "$ref": "#/definitions/fontFamilyToken"
        }
      ]
    },
    "body": {
      "description": "Font family used for <p>, <li>, etc.",
      "allOf": [
        {
          "$ref": "#/definitions/fontFamilyToken"
        }
      ]
    },
    "code": {
      "description": "Font family used within <code> blocks",
      "allOf": [
        {
          "$ref": "#/definitions/fontFamilyToken"
        }
      ]
    }
  }
}
