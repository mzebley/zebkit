{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-breakpoint Token Overrides",
  "description": "Authorable overrides for the zbk-breakpoint token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "dimensionValue": {
      "oneOf": [
        {
          "type": [
            "string",
            "number"
          ]
        },
        {
          "type": "object",
          "required": [
            "value",
            "unit"
          ],
          "additionalProperties": false,
          "properties": {
            "value": {
              "type": "number"
            },
            "unit": {
              "type": "string",
              "enum": [
                "px",
                "rem"
              ]
            }
          }
        }
      ],
      "examples": [
        "{breakpoint.tablet}",
        "{breakpoint.tablet-lg}",
        "{breakpoint.desktop}",
        "{breakpoint.desktop-lg}",
        "{breakpoint.widescreen}"
      ]
    }
  },
  "properties": {
    "$extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": {
                "oneOf": [
                  {
                    "type": [
                      "string",
                      "number"
                    ]
                  },
                  {
                    "type": "object",
                    "required": [
                      "value",
                      "unit"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "value": {
                        "type": "number"
                      },
                      "unit": {
                        "type": "string",
                        "enum": [
                          "px",
                          "rem"
                        ]
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    "tablet": {
      "type": "object",
      "description": "Small tablets and large phones in landscape (640px).",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/dimensionValue"
        },
        "$type": {
          "const": "dimension"
        },
        "$description": {
          "type": "string"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          }
        }
      }
    },
    "tablet-lg": {
      "type": "object",
      "description": "Large tablets (800px).",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/dimensionValue"
        },
        "$type": {
          "const": "dimension"
        },
        "$description": {
          "type": "string"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
