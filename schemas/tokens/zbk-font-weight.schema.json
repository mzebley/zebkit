{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-font-weight Token Overrides",
  "description": "Authorable overrides for the zbk-font-weight token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "fontWeightValue": {
      "type": [
        "string",
        "number"
      ],
      "examples": [
        "{h1.font-weight}",
        "{h2.font-weight}",
        "{h3.font-weight}",
        "{h4.font-weight}",
        "{h5.font-weight}",
        "{h6.font-weight}",
        "{lede.font-weight}",
        "{list.font-weight}",
        "{p.font-weight}",
        "{font-weight.thin}",
        "{font-weight.extralight}",
        "{font-weight.light}",
        "{font-weight.normal}",
        "{font-weight.medium}",
        "{font-weight.semibold}",
        "{font-weight.bold}",
        "{font-weight.extrabold}",
        "{font-weight.black}",
        "{button.font-weight}",
        "{checkbox.font-weight}",
        "{input.font-weight}",
        "{input.label-font-weight}",
        "{pagination.font-weight}",
        "{radio.font-weight}",
        "{select.font-weight}",
        "{select.label-font-weight}",
        "{textarea.font-weight}",
        "{textarea.label-font-weight}",
        "{toggle.font-weight}",
        "{tooltip.font-weight}"
      ]
    }
  },
  "properties": {
    "$extensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": {
                "oneOf": [
                  {
                    "type": [
                      "string",
                      "number"
                    ]
                  },
                  {
                    "type": "object",
                    "required": [
                      "value",
                      "unit"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "value": {
                        "type": "number"
                      },
                      "unit": {
                        "type": "string",
                        "enum": [
                          "px",
                          "rem"
                        ]
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    "thin": {
      "type": "object",
      "description": "Lightest font weight.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/fontWeightValue"
        },
        "$type": {
          "const": "fontWeight"
        },
        "$description": {
          "type": "string"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          }
        }
      }
    },
