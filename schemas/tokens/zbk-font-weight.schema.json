{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-font-weight Token Overrides",
  "description": "Authorable overrides for the zbk-font-weight token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "fontWeightValue": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 1,
          "maximum": 1000
        },
        {
          "type": "string",
          "enum": [
            "thin",
            "hairline",
            "extra-light",
            "ultra-light",
            "light",
            "normal",
            "regular",
            "book",
            "medium",
            "semi-bold",
            "demi-bold",
            "bold",
            "extra-bold",
            "ultra-bold",
            "black",
            "heavy",
            "extra-black",
            "ultra-black"
          ]
        },
        {
          "type": "string",
          "pattern": "^\\{[^{}]+\\}$"
        }
      ],
      "examples": [
        "{h1.font-weight}",
        "{h2.font-weight}",
        "{h3.font-weight}",
        "{h4.font-weight}",
        "{h5.font-weight}",
        "{h6.font-weight}",
        "{lede.font-weight}",
        "{list.font-weight}",
        "{p.font-weight}",
        "{font-weight.thin}",
        "{font-weight.extralight}",
        "{font-weight.light}",
        "{font-weight.normal}",
        "{font-weight.medium}",
        "{font-weight.semibold}",
        "{font-weight.bold}",
        "{font-weight.extrabold}",
        "{font-weight.black}",
        "{button.font-weight}",
        "{checkbox.font-weight}",
        "{input.font-weight}",
        "{input.label-font-weight}",
        "{pagination.font-weight}",
        "{radio.font-weight}",
        "{select.font-weight}",
        "{select.label-font-weight}",
        "{textarea.font-weight}",
        "{textarea.label-font-weight}",
        "{toggle.font-weight}",
        "{tooltip.font-weight}"
      ]
    },
    "fontWeightToken": {
      "type": "object",
      "description": "Lightest font weight.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/fontWeightValue"
        },
        "$type": {
          "const": "fontWeight"
        },
        "$description": {
          "type": "string"
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      }
    },
    "deprecated": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ]
    },
    "groupType": {
      "type": "string",
      "enum": [
        "color",
        "dimension",
        "duration",
        "fontFamily",
        "fontWeight",
        "cubicBezier",
        "number",
        "strokeStyle",
        "shadow",
        "display",
        "cursor",
        "textTransform",
        "textDecoration",
        "textAlignment",
        "fontStyle",
        "transform",
        "transitionProperty",
        "transitionTimingFunction",
        "content",
        "flex",
        "utility",
        "asset",
        "boolean",
        "cssDimension"
      ]
    },
    "groupExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": false,
              "properties": {
                "min-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        }
      },
      "patternProperties": {
        "^(?!dev\\.zebkit$).+": {}
      }
    }
  },
  "properties": {
    "$type": {
      "$ref": "#/definitions/groupType"
    },
    "$description": {
      "type": "string"
    },
    "$deprecated": {
      "$ref": "#/definitions/deprecated"
    },
    "$extensions": {
      "$ref": "#/definitions/groupExtensions"
    },
    "thin": {
      "description": "Lightest font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "extralight": {
      "description": "Lighter font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "light": {
      "description": "Light font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "normal": {
      "description": "Default font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "medium": {
      "description": "Medium font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "semibold": {
      "description": "Semibold font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "bold": {
      "description": "Bold font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "extrabold": {
      "description": "Bolder font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    },
    "black": {
      "description": "Boldest font weight.",
      "allOf": [
        {
          "$ref": "#/definitions/fontWeightToken"
        }
      ]
    }
  }
}
