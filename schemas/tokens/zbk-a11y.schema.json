    "utilityToken": {
      "type": "object",
      "description": "Amount to multiply spacing variables by (independent density dial).",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/utilityValue"
        },
        "$type": {
          "const": "utility"
        },
        "$description": {
          "type": "string"
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      }
    },
    "dimensionToken": {
      "type": "object",
      "description": "Minimum height and width for interactive elements like links or buttons. WCAG AA is >= 24px, AAA is 44px",
      "required": [
        "$value"
      ],
