          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "min-interaction-size": {
      "type": "object",
      "description": "Minimum height and width for interactive elements like links or buttons. WCAG AA is >= 24px, AAA is 44px",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/definitions/spacingValue"
        },
