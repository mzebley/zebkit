  "properties": {
    "spacing-modifier": {
      "type": "object",
      "description": "Amount to multiply spacing variables by (independent density dial).",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/definitions/utilityValue"
        },
        "type": {
          "const": "utility"
        },
        "description": {
          "type": "string"
        },
        "a11y": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "additional": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "spacing-text-coupling": {
      "type": "object",
      "description": "How hard spacing follows body (md) font-size growth: 1 = 1:1, 0 = decoupled. Lets containers grow with text without a separate density bump.",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/definitions/utilityValue"
        },
        "type": {
          "const": "utility"
        },
        "description": {
          "type": "string"
        },
        "a11y": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "additional": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "line-height-modifier": {
      "type": "object",
      "description": "Amount to multiply line height variables by.",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/definitions/utilityValue"
        },
        "type": {
          "const": "utility"
        },
        "description": {
          "type": "string"
        },
        "a11y": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "additional": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "letter-spacing-modifier": {
      "type": "object",
      "description": "Amount to multiply letter spacing variables by.",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/definitions/utilityValue"
        },
        "type": {
          "const": "utility"
        },
        "description": {
          "type": "string"
        },
        "a11y": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "additional": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "fallback-font-size-modifier": {
      "type": "object",
      "description": "Fallback amount to multiply font size variables by in the event their specific modifier isn't set.",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/definitions/utilityValue"
        },
        "type": {
          "const": "utility"
        },
        "description": {
          "type": "string"
        },
        "a11y": {
          "type": [
            "boolean",
            "string"
          ]
        },
        "additional": {
          "type": [
            "string",
            "number",
            "boolean"
          ]
        }
      }
    },
    "transition-duration-modifier": {
      "type": "object",
      "description": "Amount to multiply transition durations by (automatically set to 0 with media query match for 'prefers-reduced-motion'",
      "required": [
        "value"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/definitions/utilityValue"
