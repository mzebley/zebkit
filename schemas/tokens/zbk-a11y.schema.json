    "groupExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": false,
              "properties": {
                "min-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        }
      },
      "patternProperties": {
        "^(?!dev\\.zebkit$).+": {}
      }
    },
