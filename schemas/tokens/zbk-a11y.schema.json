{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-a11y Token Overrides",
  "description": "Authorable overrides for the zbk-a11y token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "utilityValue": {
      "type": [
        "string",
        "number"
      ],
      "examples": [
        "{a11y.spacing-modifier}",
        "{a11y.spacing-text-coupling}",
        "{a11y.line-height-modifier}",
        "{a11y.letter-spacing-modifier}",
        "{a11y.fallback-font-size-modifier}",
