{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-line-height Token Overrides",
  "description": "Authorable overrides for the zbk-line-height token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "lineHeightValue": {
      "type": [
        "string",
        "number"
      ],
      "examples": [
        "{h1.line-height}",
        "{h2.line-height}",
        "{h3.line-height}",
        "{h4.line-height}",
        "{h5.line-height}",
        "{h6.line-height}",
        "{lede.line-height}",
        "{list.line-height}",
        "{p.line-height}",
        "{line-height.1}",
        "{line-height.2}",
        "{line-height.3}",
        "{line-height.4}",
        "{line-height.5}",
        "{button.line-height}",
        "{checkbox.line-height}",
        "{input.line-height}",
        "{pagination.line-height}",
        "{radio.line-height}",
        "{select.line-height}",
        "{textarea.field-line-height}",
        "{toggle.line-height}",
        "{tooltip.line-height}"
      ]
    }
  },
  "properties": {
    "1": {
      "type": "object",
      "description": "Smallest line height.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/lineHeightValue"
        },
        "$type": {
          "const": "lineHeight"
        },
        "$description": {
          "type": "string"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          }
        }
      }
    },
