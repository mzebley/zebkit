      "examples": [
        "{spacing.max-scale}",
        "{font-size.min-viewport}",
        "{font-size.max-viewport}",
        "{font-size.min-base}",
        "{font-size.max-base}",
        "{font-size.min-ratio}",
        "{font-size.max-ratio}"
      ]
    },
    "rootFontSizeValue": {
