      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/cssDimensionValue"
        },
        "$type": {
          "const": "cssDimension"
        },
        "$description": {
          "type": "string"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          }
        }
      }
