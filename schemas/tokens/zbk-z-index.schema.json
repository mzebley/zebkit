{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-z-index Token Overrides",
  "description": "Authorable overrides for the zbk-z-index token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "numberValue": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "minLength": 1,
          "examples": [
            "{z-index.auto}"
          ]
        }
      ],
      "examples": [
        "{a11y.spacing-modifier}",
        "{a11y.spacing-text-coupling}",
        "{a11y.line-height-modifier}",
        "{a11y.letter-spacing-modifier}",
        "{a11y.fallback-font-size-modifier}",
        "{a11y.transition-duration-modifier}",
        "{opacity.0}",
        "{opacity.5}",
        "{opacity.10}",
        "{opacity.15}",
        "{opacity.20}",
        "{opacity.25}",
        "{opacity.30}",
        "{opacity.40}",
        "{opacity.50}",
        "{opacity.60}",
        "{opacity.70}",
        "{opacity.75}",
        "{opacity.80}",
        "{opacity.85}",
        "{opacity.90}",
        "{opacity.95}",
        "{opacity.100}",
        "{h1.line-height}",
        "{h2.line-height}",
        "{h3.line-height}",
        "{h4.line-height}",
        "{h5.line-height}",
        "{h6.line-height}",
        "{lede.line-height}",
        "{list.line-height}",
        "{p.line-height}",
        "{line-height.1}",
        "{line-height.2}",
        "{line-height.3}",
        "{line-height.4}",
        "{line-height.5}",
        "{z-index.0}",
        "{z-index.10}",
        "{z-index.20}",
        "{z-index.30}",
        "{z-index.40}",
        "{z-index.50}",
        "{z-index.60}",
        "{z-index.70}",
        "{z-index.80}",
        "{z-index.90}",
        "{z-index.100}",
        "{z-index.dropdown}",
        "{z-index.sticky}",
        "{z-index.fixed}",
        "{z-index.modal-backdrop}",
        "{z-index.modal}",
        "{z-index.popover}",
        "{z-index.tooltip}",
        "{button.line-height}",
        "{button.opacity}",
        "{button.opacity-loading}",
        "{checkbox.line-height}",
        "{checkbox.opacity}",
        "{checkbox.opacity-disabled}",
        "{input.line-height}",
        "{input.opacity}",
        "{input.opacity-disabled}",
        "{pagination.line-height}",
        "{radio.line-height}",
        "{radio.opacity}",
        "{radio.opacity-disabled}",
        "{select.line-height}",
        "{select.opacity}",
        "{select.opacity-disabled}",
        "{textarea.field-line-height}",
        "{textarea.opacity}",
        "{textarea.opacity-disabled}",
        "{toggle.line-height}",
        "{toggle.opacity}",
        "{toggle.opacity-disabled}",
        "{tooltip.line-height}",
        "{tooltip.z-index}",
        "{tooltip.opacity}"
      ]
    },
    "cssNumberValue": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "{z-index.auto}"
      ]
    },
    "numberToken": {
      "type": "object",
      "description": "Base stacking level.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "anyOf": [
            {
              "$ref": "#/definitions/numberValue"
            },
            {
              "$ref": "#/definitions/cssNumberValue"
            }
          ]
        },
        "$type": {
          "type": "string",
          "enum": [
            "number",
            "cssNumber"
          ]
        },
        "$description": {
          "type": "string",
          "minLength": 1
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "$type"
            ],
            "properties": {
              "$type": {
                "const": "number"
              }
            }
          },
          "then": {
            "properties": {
              "$value": {
                "$ref": "#/definitions/numberValue"
              }
            }
          }
        },
        {
          "if": {
            "required": [
              "$type"
            ],
            "properties": {
              "$type": {
                "const": "cssNumber"
              }
            }
          },
          "then": {
            "properties": {
              "$value": {
                "$ref": "#/definitions/cssNumberValue"
              }
            }
          }
        }
      ]
    },
    "cssNumberToken": {
      "type": "object",
      "description": "Auto z-index, lets browser determine stacking.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/cssNumberValue"
        },
        "$type": {
          "const": "cssNumber"
        },
        "$description": {
          "type": "string",
          "minLength": 1
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      }
    },
    "deprecated": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ]
    },
    "groupExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": false,
              "properties": {
                "min-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        }
      },
      "patternProperties": {
        "^(?!dev\\.zebkit$).+": {}
      }
    },
    "group:modal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "$type": {
          "type": "string",
          "enum": [
            "number",
            "cssNumber"
          ]
        },
        "$description": {
          "type": "string",
          "minLength": 1
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "$ref": "#/definitions/groupExtensions"
        },
        "backdrop": {
          "description": "Semantic z-index for modal backdrops/overlays.",
          "allOf": [
            {
              "$ref": "#/definitions/numberToken"
            }
          ]
        }
      }
    }
  },
  "properties": {
    "0": {
      "description": "Base stacking level.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "10": {
      "description": "Low elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "20": {
      "description": "Slight elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "30": {
      "description": "Medium-low elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "40": {
      "description": "Medium elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "50": {
      "description": "Medium-high elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "60": {
      "description": "High elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "70": {
      "description": "Higher elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "80": {
      "description": "Very high elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "90": {
      "description": "Near-top elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "100": {
      "description": "Top-level elevation stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "$type": {
      "type": "string",
      "enum": [
        "number",
        "cssNumber"
      ]
    },
    "$description": {
      "type": "string",
      "minLength": 1
    },
    "$deprecated": {
      "$ref": "#/definitions/deprecated"
    },
    "$extensions": {
      "$ref": "#/definitions/groupExtensions"
    },
    "auto": {
      "description": "Auto z-index, lets browser determine stacking.",
      "allOf": [
        {
          "$ref": "#/definitions/cssNumberToken"
        }
      ]
    },
    "dropdown": {
      "description": "Semantic z-index for dropdown menus.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "sticky": {
      "description": "Semantic z-index for sticky positioned elements.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "fixed": {
      "description": "Semantic z-index for fixed positioned elements.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "modal": {
      "anyOf": [
        {
          "description": "Semantic z-index for modal dialogs.",
          "allOf": [
            {
              "$ref": "#/definitions/numberToken"
            }
          ]
        },
        {
          "$ref": "#/definitions/group:modal"
        }
      ]
    },
    "modal-backdrop": {
      "description": "Semantic z-index for modal backdrops/overlays.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "popover": {
      "description": "Semantic z-index for popovers.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "tooltip": {
      "description": "Semantic z-index for tooltips (highest).",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    }
  }
}
