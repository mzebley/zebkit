{
  "$schema": "http://json-schema.org/draft-07/schema",
  "title": "Zebkit zbk-z-index Token Overrides",
  "description": "Authorable overrides for the zbk-z-index token module.",
  "type": "object",
  "additionalProperties": false,
  "definitions": {
    "numberValue": {
      "oneOf": [
        {
          "type": "number"
        },
        {
          "type": "string",
          "pattern": "^\\{[^{}]+\\}$"
        }
      ],
      "examples": [
        "{opacity.0}",
        "{opacity.5}",
        "{opacity.10}",
        "{opacity.15}",
        "{opacity.20}",
        "{opacity.25}",
        "{opacity.30}",
        "{opacity.40}",
        "{opacity.50}",
        "{opacity.60}",
        "{opacity.70}",
        "{opacity.75}",
        "{opacity.80}",
        "{opacity.85}",
        "{opacity.90}",
        "{opacity.95}",
        "{opacity.100}",
        "{h1.line-height}",
        "{h2.line-height}",
        "{h3.line-height}",
        "{h4.line-height}",
        "{h5.line-height}",
        "{h6.line-height}",
        "{lede.line-height}",
        "{list.line-height}",
        "{p.line-height}",
        "{line-height.1}",
        "{line-height.2}",
        "{line-height.3}",
        "{line-height.4}",
        "{line-height.5}",
        "{z-index.0}",
        "{z-index.10}",
        "{z-index.20}",
        "{z-index.30}",
        "{z-index.40}",
        "{z-index.50}",
        "{z-index.60}",
        "{z-index.70}",
        "{z-index.80}",
        "{z-index.90}",
        "{z-index.100}",
        "{z-index.dropdown}",
        "{z-index.sticky}",
        "{z-index.fixed}",
        "{z-index.modal-backdrop}",
        "{z-index.modal}",
        "{z-index.popover}",
        "{z-index.tooltip}",
        "{button.line-height}",
        "{button.opacity}",
        "{button.opacity-loading}",
        "{checkbox.line-height}",
        "{checkbox.opacity}",
        "{checkbox.opacity-disabled}",
        "{input.line-height}",
        "{input.opacity}",
        "{input.opacity-disabled}",
        "{pagination.line-height}",
        "{radio.line-height}",
        "{radio.opacity}",
        "{radio.opacity-disabled}",
        "{select.line-height}",
        "{select.opacity}",
        "{select.opacity-disabled}",
        "{textarea.field-line-height}",
        "{textarea.opacity}",
        "{textarea.opacity-disabled}",
        "{toggle.line-height}",
        "{toggle.opacity}",
        "{toggle.opacity-disabled}",
        "{tooltip.line-height}",
        "{tooltip.z-index}",
        "{tooltip.opacity}"
      ]
    },
    "cssDimensionValue": {
      "type": "string",
      "examples": [
        "{h1.font-size}",
        "{h1.measure}",
        "{h2.font-size}",
        "{h2.measure}",
        "{h3.font-size}",
        "{h3.measure}",
        "{h4.font-size}",
        "{h4.measure}",
        "{h5.font-size}",
        "{h5.measure}",
        "{h6.font-size}",
        "{h6.measure}",
        "{lede.font-size}",
        "{lede.measure}",
        "{list.font-size}",
        "{list.measure}",
        "{p.font-size}",
        "{p.measure}",
        "{text-measure.1}",
        "{text-measure.2}",
        "{text-measure.3}",
        "{text-measure.4}",
        "{text-measure.5}",
        "{font-size.3xs}",
        "{font-size.2xs}",
        "{font-size.xs}",
        "{font-size.sm}",
        "{font-size.md}",
        "{font-size.lg}",
        "{font-size.xl}",
        "{font-size.2xl}",
        "{font-size.3xl}",
        "{font-size.4xl}",
        "{font-size.5xl}",
        "{z-index.auto}",
        "{button.font-size}",
        "{button.letter-spacing}",
        "{button.margin-inline}",
        "{button.margin-block}",
        "{button.margin-inline-start}",
        "{button.margin-inline-end}",
        "{button.margin-block-start}",
        "{button.margin-block-end}",
        "{button.width}",
        "{button.max-width}",
        "{button.height}",
        "{button.max-height}",
        "{button.icon-size}",
        "{button.icon-start-size}",
        "{button.icon-end-size}",
        "{checkbox.indicator-size}",
        "{checkbox.font-size}",
        "{checkbox.letter-spacing}",
        "{input.font-size}",
        "{input.letter-spacing}",
        "{input.label-font-size}",
        "{input.icon-size}",
        "{input.width}",
        "{input.min-width}",
        "{input.max-width}",
        "{pagination.font-size}",
        "{pagination.icon-size}",
        "{radio.border-radius}",
        "{radio.indicator-size}",
        "{radio.indicator-radius}",
        "{radio.font-size}",
        "{radio.letter-spacing}",
        "{select.font-size}",
        "{select.letter-spacing}",
        "{select.label-font-size}",
        "{select.icon-size}",
        "{select.indicator-size}",
        "{select.width}",
        "{select.min-width}",
        "{select.max-width}",
        "{textarea.font-size}",
        "{textarea.letter-spacing}",
        "{textarea.label-font-size}",
        "{textarea.width}",
        "{textarea.min-width}",
        "{textarea.max-width}",
        "{toggle.thumb-radius}",
        "{toggle.font-size}",
        "{toggle.letter-spacing}",
        "{tooltip.font-size}",
        "{tooltip.letter-spacing}"
      ]
    },
    "numberToken": {
      "type": "object",
      "description": "Base stacking level.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/numberValue"
        },
        "$type": {
          "const": "number"
        },
        "$description": {
          "type": "string"
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      }
    },
    "cssDimensionToken": {
      "type": "object",
      "description": "Auto z-index, lets browser determine stacking.",
      "required": [
        "$value"
      ],
      "additionalProperties": false,
      "properties": {
        "$value": {
          "$ref": "#/definitions/cssDimensionValue"
        },
        "$type": {
          "const": "cssDimension"
        },
        "$description": {
          "type": "string"
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "dev.zebkit": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "a11y": {
                  "type": [
                    "boolean",
                    "string"
                  ],
                  "description": "Runtime accessibility-modifier opt-in: true uses the default modifier for the token type; a string names a custom modifier variable."
                }
              }
            }
          },
          "patternProperties": {
            "^(?!dev\\.zebkit$).+": {}
          }
        }
      }
    },
    "deprecated": {
      "oneOf": [
        {
          "type": "boolean"
        },
        {
          "type": "string"
        }
      ]
    },
    "groupType": {
      "type": "string",
      "enum": [
        "color",
        "dimension",
        "duration",
        "fontFamily",
        "fontWeight",
        "cubicBezier",
        "number",
        "strokeStyle",
        "shadow",
        "display",
        "cursor",
        "textTransform",
        "textDecoration",
        "textAlignment",
        "fontStyle",
        "transform",
        "transitionProperty",
        "transitionTimingFunction",
        "content",
        "flex",
        "utility",
        "asset",
        "boolean",
        "cssDimension"
      ]
    },
    "groupExtensions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dev.zebkit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scale": {
              "type": "object",
              "description": "Fluid-scale controls for this module (e.g. min-viewport/max-viewport/min-base/max-base/min-ratio/max-ratio on font-size, max-scale on spacing).",
              "additionalProperties": false,
              "properties": {
                "min-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-viewport": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "max-base": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "value",
                        "unit"
                      ],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "number"
                        },
                        "unit": {
                          "type": "string",
                          "enum": [
                            "px",
                            "rem"
                          ]
                        }
                      }
                    },
                    {
                      "type": "string",
                      "pattern": "^-?(?:\\d+|\\d*\\.\\d+)(?:px|rem)$"
                    }
                  ]
                },
                "min-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-ratio": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "max-scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                }
              }
            }
          }
        }
      },
      "patternProperties": {
        "^(?!dev\\.zebkit$).+": {}
      }
    },
    "group:modal": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "$type": {
          "$ref": "#/definitions/groupType"
        },
        "$description": {
          "type": "string"
        },
        "$deprecated": {
          "$ref": "#/definitions/deprecated"
        },
        "$extensions": {
          "$ref": "#/definitions/groupExtensions"
        },
        "backdrop": {
          "description": "Semantic z-index for modal backdrops/overlays.",
          "allOf": [
            {
              "$ref": "#/definitions/numberToken"
            }
          ]
        }
      }
    }
  },
  "properties": {
    "0": {
      "description": "Base stacking level.",
      "allOf": [
        {
          "$ref": "#/definitions/numberToken"
        }
      ]
    },
    "10": {
